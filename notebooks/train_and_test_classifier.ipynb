    "\n",
    "print(\"\\n\" + \"=\"*50)\n",
    "print(f\"Mean Accuracy:  {cv_scores.mean():.1%} (± {cv_scores.std():.1%})\")\n",
    "print(f\"Min Accuracy:   {cv_scores.min():.1%}\")\n",
    "print(f\"Max Accuracy:   {cv_scores.max():.1%}\")\n",
    "\n",
    "if cv_scores.std() < 0.05:\n",
    "    print(\"\\n Very stable performance across folds!\")\n",
    "elif cv_scores.std() < 0.10:\n",
    "    print(\"\\n Stable performance\")\n",
    "else:\n",
    "    print(\"\\n High variance - results may be unstable\")\n",
    "\n",
    "# Visualize\n",
    "fig, ax = plt.subplots(figsize=(10, 5))\n",
