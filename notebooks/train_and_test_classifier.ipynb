  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 📊 Feature Space Visualization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load 2D embeddings for visualization\n",
    "from sklearn.decomposition import PCA\n",
    "from sklearn.manifold import TSNE\n",
    "\n",
    "# Create 2D projection if not already done\n",
    "if features.shape[1] > 2:\n",
    "    print(\"Creating 2D projection for visualization...\")\n",
    "    pca_2d = PCA(n_components=2, random_state=42)\n",
    "    features_2d = pca_2d.fit_transform(features)\n",
    "    print(f\"   Variance explained: {pca_2d.explained_variance_ratio_.sum():.1%}\")\n",
    "else:\n",
    "    features_2d = features\n",
    "\n",
    "# Plot\n",
    "fig, ax = plt.subplots(figsize=(10, 8))\n",
    "\n",
    "labels = clusters_df['cluster'].values\n",
    "colors_map = {0: '#3498db', 1: '#e74c3c', 2: '#2ecc71', 3: '#f39c12'}\n",
    "\n",
    "for cluster_id in np.unique(labels):\n",
    "    mask = labels == cluster_id\n",
    "    ax.scatter(\n",
    "        features_2d[mask, 0],\n",
    "        features_2d[mask, 1],\n",
    "        c=colors_map[cluster_id],\n",
    "        label=f'Cluster {cluster_id}',\n",
    "        s=100,\n",
    "        alpha=0.6,\n",
    "        edgecolors='black',\n",
    "        linewidth=0.5\n",
    "    )\n",
    "    \n",
    "    # Mark cluster center\n",
    "    center = features_2d[mask].mean(axis=0)\n",
    "    ax.scatter(center[0], center[1], \n",
    "              marker='*', s=500, c='red', \n",
    "              edgecolors='black', linewidth=2, zorder=10)\n",
    "\n",
    "ax.set_xlabel('Component 1', fontsize=12)\n",
    "ax.set_ylabel('Component 2', fontsize=12)\n",
    "ax.set_title('Cluster Separation in Feature Space', fontsize=14, fontweight='bold')\n",
    "ax.legend(fontsize=11)\n",
    "ax.grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\" Clusters visualized in 2D space\")\n",
    "print(\"   Red stars = cluster centers\")\n",
    "print(\"   Well-separated = good for classification!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 3️ Create Training Labels\n",
    "\n",
    "**Label your clusters based on what you heard:**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define cluster names\n",
    "# MODIFY THESE based on what you heard!\n",
    "cluster_names = {\n",
    "    0: \"Type A\",  # Replace with your interpretation (e.g., \"Contact calls\")\n",
    "    1: \"Type B\"   # Replace with your interpretation (e.g., \"Alarm calls\")\n",
    "}\n",
    "\n",
    "print(\" CLUSTER LABELS:\")\n",
    "print(\"=\"*50)\n",
    "for cluster_id, name in cluster_names.items():\n",
    "    count = (clusters_df['cluster'] == cluster_id).sum()\n",
    "    print(f\"Cluster {cluster_id} = '{name}': {count} rumbles\")\n",
    "\n",
    "# Create labels.json\n",
    "labels_dict = dict(zip(\n",
    "    clusters_df['filename'],\n",
    "    clusters_df['cluster']\n",
    "))\n",
    "\n",
    "# Save\n",
    "Path('data').mkdir(exist_ok=True)\n",
    "with open('data/labels.json', 'w') as f:\n",
    "    json.dump(labels_dict, f, indent=2)\n",
    "\n",
    "print(\"\\n Saved: data/labels.json\")\n",
    "print(f\"   {len(labels_dict)} files labeled\")\n",
    "\n",
    "# Also save semantic labels\n",
    "labels_semantic = dict(zip(\n",
    "    clusters_df['filename'],\n",
    "    clusters_df['cluster'].map(cluster_names)\n",
    "))\n",
    "\n",
    "with open('data/labels_semantic.json', 'w') as f:\n",
    "    json.dump(labels_semantic, f, indent=2)\n",
    "\n",
    "print(\" Saved: data/labels_semantic.json\")\n",
    "\n",
    "# Show example\n",
    "print(\"\\n Example labels:\")\n",
    "print(json.dumps(dict(list(labels_dict.items())[:3]), indent=2))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 4️ Prepare Training Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Extract labels array\n",
    "y = clusters_df['cluster'].values\n",
    "X = features  # Already normalized/PCA'd\n",
    "\n",
    "print(\" Data Summary:\")\n",
    "print(\"=\"*50)\n",
    "print(f\"Total samples: {len(X)}\")\n",
    "print(f\"Feature dimensions: {X.shape[1]}\")\n",
    "print(f\"Number of classes: {len(np.unique(y))}\")\n",
    "print(f\"Class distribution:\")\n",
    "for i in np.unique(y):\n",
    "    count = (y == i).sum()\n",
    "    print(f\"  Class {i} ({cluster_names[i]}): {count} samples ({count/len(y)*100:.1f}%)\")\n",
    "\n",
    "# Train/test split (stratified to maintain class balance)\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y, \n",
    "    test_size=0.2,  # 80/20 split\n",
    "    random_state=42,\n",
    "    stratify=y  # Keep class proportions\n",
    ")\n",
    "\n",
    "print(f\"\\n Data split:\")\n",
    "print(f\"   Training:   {len(X_train)} samples ({len(X_train)/len(X)*100:.1f}%)\")\n",
    "print(f\"   Testing:    {len(X_test)} samples ({len(X_test)/len(X)*100:.1f}%)\")\n",
    "\n",
    "# Verify stratification\n",
    "print(f\"\\n Class balance preserved:\")\n",
    "print(\"\\nTraining set:\")\n",
    "for i in np.unique(y_train):\n",
    "    count = (y_train == i).sum()\n",
    "    print(f\"  Class {i}: {count} ({count/len(y_train)*100:.1f}%)\")\n",
    "    \n",
    "print(\"\\nTest set:\")\n",
    "for i in np.unique(y_test):\n",
    "    count = (y_test == i).sum()\n",
    "    print(f\"  Class {i}: {count} ({count/len(y_test)*100:.1f}%)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 5️ Train Classifiers\n",
    "\n",
    "### Option A: Random Forest (Fast & Interpretable)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\" Training Random Forest Classifier...\\n\")\n",
    "\n",
    "# Train model\n",
    "rf_clf = RandomForestClassifier(\n",
    "    n_estimators=200,      # Number of trees\n",
    "    max_depth=15,          # Max tree depth\n",
    "    min_samples_split=5,   # Min samples to split\n",
    "    min_samples_leaf=2,    # Min samples in leaf\n",
    "    random_state=42,\n",
    "    n_jobs=-1,             # Use all CPU cores\n",
    "    verbose=0\n",
    ")\n",
    "\n",
    "# Fit\n",
    "rf_clf.fit(X_train, y_train)\n",
    "\n",
    "# Predictions\n",
    "y_train_pred_rf = rf_clf.predict(X_train)\n",
    "y_test_pred_rf = rf_clf.predict(X_test)\n",
    "\n",
    "# Probabilities\n",
    "y_test_proba_rf = rf_clf.predict_proba(X_test)\n",
    "\n",
    "# Accuracy\n",
    "train_acc_rf = accuracy_score(y_train, y_train_pred_rf)\n",
    "test_acc_rf = accuracy_score(y_test, y_test_pred_rf)\n",
    "\n",
    "print(\" Training complete!\\n\")\n",
    "print(\" Performance:\")\n",
    "print(f\"   Train Accuracy: {train_acc_rf:.1%}\")\n",
    "print(f\"   Test Accuracy:  {test_acc_rf:.1%}\")\n",
    "\n",
    "# Check for overfitting\n",
    "if train_acc_rf - test_acc_rf > 0.15:\n",
    "    print(\"\\n Warning: Model may be overfitting (train >> test)\")\n",
    "    print(\"   Consider: reducing max_depth or increasing min_samples_leaf\")\n",
    "else:\n",
    "    print(\"\\n Good generalization (no overfitting detected)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Option B: Support Vector Machine (High Accuracy)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\" Training SVM Classifier...\\n\")\n",
    "\n",
    "# Train SVM with RBF kernel\n",
    "svm_clf = SVC(\n",
    "    kernel='rbf',\n",
    "    C=10,                  # Regularization\n",
    "    gamma='scale',         # Kernel coefficient\n",
    "    probability=True,      # Enable probability estimates\n",
    "    random_state=42\n",
    ")\n",
    "\n",
    "svm_clf.fit(X_train, y_train)\n",
    "\n",
    "# Predictions\n",
    "y_train_pred_svm = svm_clf.predict(X_train)\n",
    "y_test_pred_svm = svm_clf.predict(X_test)\n",
    "y_test_proba_svm = svm_clf.predict_proba(X_test)\n",
    "\n",
    "# Accuracy\n",
    "train_acc_svm = accuracy_score(y_train, y_train_pred_svm)\n",
    "test_acc_svm = accuracy_score(y_test, y_test_pred_svm)\n",
    "\n",
    "print(\" Training complete!\\n\")\n",
    "print(\" Performance:\")\n",
    "print(f\"   Train Accuracy: {train_acc_svm:.1%}\")\n",
    "print(f\"   Test Accuracy:  {test_acc_svm:.1%}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "###  Model Comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create comparison table\n",
    "comparison_df = pd.DataFrame({\n",
    "    'Model': ['Random Forest', 'SVM'],\n",
    "    'Train Accuracy': [train_acc_rf, train_acc_svm],\n",
    "    'Test Accuracy': [test_acc_rf, test_acc_svm],\n",
    "    'Overfitting': [\n",
    "        train_acc_rf - test_acc_rf,\n",
    "        train_acc_svm - test_acc_svm\n",
    "    ]\n",
    "})\n",
    "\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\" MODEL COMPARISON\")\n",
    "print(\"=\"*60)\n",
    "print(comparison_df.to_string(index=False))\n",
    "\n",
    "# Determine best model\n",
    "best_model_name = comparison_df.loc[comparison_df['Test Accuracy'].idxmax(), 'Model']\n",
    "best_acc = comparison_df['Test Accuracy'].max()\n",
    "\n",
    "print(f\"\\n Best Model: {best_model_name} ({best_acc:.1%} test accuracy)\")\n",
    "\n",
    "# Use best model for further analysis\n",
    "if best_model_name == 'Random Forest':\n",
    "    best_clf = rf_clf\n",
    "    y_test_pred = y_test_pred_rf\n",
    "    y_test_proba = y_test_proba_rf\n",
    "else:\n",
    "    best_clf = svm_clf\n",
    "    y_test_pred = y_test_pred_svm\n",
    "    y_test_proba = y_test_proba_svm"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 6️ Evaluate Performance\n",
    "\n",
    "### Classification Report"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\" DETAILED CLASSIFICATION REPORT\")\n",
    "print(\"=\"*70)\n",
    "print()\n",
    "\n",
    "# Get report as dict for better formatting\n",
    "report = classification_report(\n",
    "    y_test, \n",
    "    y_test_pred,\n",
    "    target_names=[cluster_names[i] for i in sorted(cluster_names.keys())],\n",
    "    output_dict=True\n",
    ")\n",
    "\n",
    "# Convert to DataFrame for nice display\n",
    "report_df = pd.DataFrame(report).transpose()\n",
    "\n",
    "# Format percentages\n",
    "for col in ['precision', 'recall', 'f1-score']:\n",
    "    if col in report_df.columns:\n",
    "        report_df[col] = report_df[col].apply(lambda x: f\"{x:.1%}\" if isinstance(x, float) else x)\n",
    "\n",
    "print(report_df.to_string())\n",
    "\n",
    "print(\"\\n\" + \"=\"*70)\n",
    "print(\" Metric Definitions:\")\n",
    "print(\"   Precision: Of predicted X, how many actually were X?\")\n",
    "print(\"   Recall:    Of actual X, how many did we find?\")\n",
    "print(\"   F1-score:  Harmonic mean of precision and recall\")\n",
    "print(\"   Support:   Number of samples in test set\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Confusion Matrix"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compute confusion matrix\n",
    "cm = confusion_matrix(y_test, y_test_pred)\n",
    "\n",
    "# Create visualization\n",
    "fig, ax = plt.subplots(figsize=(8, 6))\n",
    "\n",
    "# Plot heatmap\n",
    "sns.heatmap(\n",
    "    cm, \n",
    "    annot=True,          # Show numbers\n",
    "    fmt='d',             # Integer format\n",
    "    cmap='Blues',        # Color scheme\n",
    "    cbar=True,\n",
    "    square=True,\n",
    "    xticklabels=[cluster_names[i] for i in sorted(cluster_names.keys())],\n",
    "    yticklabels=[cluster_names[i] for i in sorted(cluster_names.keys())],\n",
    "    ax=ax,\n",
    "    annot_kws={'size': 14, 'weight': 'bold'}\n",
    ")\n",
    "\n",
    "ax.set_xlabel('Predicted Label', fontsize=12, fontweight='bold')\n",
    "ax.set_ylabel('True Label', fontsize=12, fontweight='bold')\n",
    "ax.set_title('Confusion Matrix', fontsize=14, fontweight='bold', pad=20)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Print confusion matrix stats\n",
    "print(\"\\n Confusion Matrix Analysis:\")\n",
    "print(\"=\"*50)\n",
    "\n",
    "for i, name in cluster_names.items():\n",
    "    true_pos = cm[i, i]\n",
    "    false_neg = cm[i, :].sum() - true_pos\n",
    "    false_pos = cm[:, i].sum() - true_pos\n",
    "    \n",
    "    print(f\"\\n{name}:\")\n",
    "    print(f\"  Correctly classified: {true_pos}/{cm[i, :].sum()} ({true_pos/cm[i, :].sum()*100:.1f}%)\")\n",
    "    if false_neg > 0:\n",
    "        print(f\"   Missed (false negatives): {false_neg}\")\n",
    "    if false_pos > 0:\n",
    "        print(f\"   False alarms (false positives): {false_pos}\")"
   ]
